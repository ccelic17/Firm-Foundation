{
  "expo": {
    "name": "Firm Foundation",
    "slug": "firm-foundation",
    "version": "1.0.0",
    "scheme": "firmfoundation",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0C0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ccelic.firmfoundation"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0C0F1A"
      },
      "package": "com.ccelic.firmfoundation"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
