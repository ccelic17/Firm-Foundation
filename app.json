{
  "expo": {
    "name": "Firm Foundation",
    "slug": "firm-foundation",
    "version": "1.0.0",
    "scheme": "firmfoundation",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/firm_foundation_logo_1024.png",
    "splash": {
      "backgroundColor": "#0C0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "com.firmfoundation.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0C0F1A"
      },
      "package": "com.ccelic.firmfoundation"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
